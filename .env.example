# Map Id (which generation set to use)
MAP_ID="regierungsviertel"

# Modal inference URL for the fine-tuned Qwen-Image-Edit model
MODAL_INFERENCE_URL="https://your-workspace--qwen-image-edit-server-imageeditor-edit-b64.modal.run"

# --- Optional: Cloudflare R2 for hosting DZI tiles ---
R2_ENDPOINT_URL=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_URL=""

# --- Optional: Geoportal Berlin WFS endpoint override ---
BERLIN_LOD2_WFS_URL=""

# --- Google Maps Platform (OPT-IN, additive fusion source) ---
# All three must be set for the Google 3D Tiles fetcher to run.
# NEVER commit a real API key. Use a local .env (gitignored).
GOOGLE_MAPS_API_KEY=""
GOOGLE_MAPS_3D_TILES_ENABLED="false"
GOOGLE_MAPS_TERMS_ACCEPTED="false"
